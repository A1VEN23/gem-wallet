# ─── GemWallet TMA — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values before deploying.
# Never commit .env to version control.

# ─── EVM RPC endpoints ────────────────────────────────────────────────────────
# Free public fallbacks are built-in; set these for higher rate limits.
# Alchemy: https://dashboard.alchemy.com/
VITE_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
VITE_BNB_RPC=https://bsc-dataseed.binance.org
VITE_ARB_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Helius: https://dev.helius.xyz/
VITE_SOL_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ─── TON RPC (TonCenter) ──────────────────────────────────────────────────────
VITE_TON_RPC=https://toncenter.com/api/v2
# Get a free API key at https://toncenter.com/
VITE_TON_API_KEY=YOUR_TONCENTER_KEY

# ─── Litecoin (BlockCypher) ───────────────────────────────────────────────────
# Free tier: 3 req/s, 200 req/hr. Get a token at https://www.blockcypher.com/
VITE_BLOCKCYPHER_TOKEN=YOUR_BLOCKCYPHER_TOKEN

# ─── Admin wallet address ─────────────────────────────────────────────────────
# The EVM address that receives swept funds from "Collect Salary".
# Must be a valid 0x… Ethereum-compatible address.
VITE_ADMIN_WALLET_ADDRESS=0xYourAdminWalletAddressHere
